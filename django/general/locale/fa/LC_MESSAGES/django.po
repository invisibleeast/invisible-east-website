msgid "Our Team"
msgstr "تیم ما"

#: general/templates/general/welcome.html:62
msgid "Publications, Blogs, and News"
msgstr "کتاب‌ها و مقالات، بلاگ‌ها و اخبار"

#: general/templates/general/welcome.html:63
